---

<BaseLayout
    title="Kompostárna Krhov | Služby Musil - Prodej kompostu a likvidace bioodpadu"
    fullWidth={true}
    transparentNav={true}
>
    <Hero
        image="/images/kompostarna/hero.webp"
        imageAlt="Kompostárna Krhov - Služby Musil"
    >
        <Fragment slot="title">
            Kompostárna <br />
            <span class="text-amber-500">Krhov</span>
        </Fragment>
        <Fragment slot="subtitle">
            Nabízíme vysoce kvalitní certifikovaný kompost a substráty. Zároveň
            zajišťujeme ekologickou likvidaci bioodpadu ze zahrad i lesnictví.
        </Fragment>
        <Fragment slot="actions">
            <a
                href="#prodej"
                class="inline-block bg-amber-500 hover:bg-amber-600 text-slate-900 font-bold py-4 px-8 rounded-lg transition-transform hover:scale-105 shadow-lg uppercase tracking-wider text-sm"
            >
                Koupit kompost
            </a>
            <a
                href="#likvidace"
                class="inline-block bg-white/10 hover:bg-white/20 text-white border border-white/20 font-bold py-4 px-8 rounded-lg transition-all uppercase tracking-wider backdrop-blur-sm text-sm"
            >
                Likvidace bioodpadu
            </a>
        </Fragment>
    </Hero>

    <!-- Main Content Section -->
    <section class="py-16 md:py-24 bg-white">
        <div class="container mx-auto px-4">
            <div class="max-w-5xl mx-auto space-y-24">
                <!-- 1. Prodej produktů -->
                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center scroll-mt-24 md:scroll-mt-32"
                    id="prodej"
                >
                    <div class="space-y-8">
                        <h2
                            class="text-3xl md:text-5xl font-extrabold text-slate-900 leading-tight"
                        >
                            Kvalitní zahradní <br />kompost a substráty
                        </h2>
                        <p class="text-lg text-slate-600 leading-relaxed">
                            Náš kompost je výsledkem pečlivého procesu
                            zpracování v našem zařízení. Je bohatý na klíčové
                            živiny a ideální pro rekultivaci půdy, hnojení
                            zahrad nebo jako základ pro pěstování rostlin. <button
                                id="openAnalysis"
                                class="text-amber-600 font-bold underline hover:text-amber-700 transition-colors"
                                >Rozbor kompostu</button
                            >.
                        </p>

                        <div
                            class="bg-amber-50 rounded-xl p-4 border border-amber-100 flex items-start gap-3"
                        >
                            <div
                                class="bg-amber-500 rounded-lg p-2 text-white shrink-0"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"
                                    ></path>
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 011 1v1m4-1a1 1 0 011 1v1m-1-4h3a1 1 0 001-1V11a1 1 0 00-1-1h-3V8a1 1 0 00-1-1h-5"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 text-sm">
                                    Zajistíme vám i dopravu
                                </h4>
                                <p class="text-xs text-slate-600 leading-tight">
                                    Zakoupený kompost či substrát vám rádi
                                    dovezeme. Cena dopravy je na zavolání dle
                                    množství a vzdálenosti.
                                </p>
                            </div>
                        </div>
                        <div class="pt-4 flex flex-wrap gap-4">
                            <a
                                href={url("/kontakt")}
                                class="inline-block bg-amber-500 hover:bg-amber-600 text-slate-900 font-bold py-3 px-8 rounded-lg transition-all hover:scale-105 uppercase tracking-wider text-sm shadow-md"
                            >
                                Poptat
                            </a>
                            <a
                                href={`tel:${CONTACT_INFO.phonePlain}`}
                                class="inline-block bg-white border-2 border-slate-200 hover:border-slate-900 text-slate-700 hover:text-slate-900 font-bold py-3 px-8 rounded-lg transition-all hover:scale-105 uppercase tracking-wider text-sm"
                            >
                                Volejte {CONTACT_INFO.phone}
                            </a>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <!-- Kompost -->
                        <div
                            class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-100 shadow-sm flex flex-col group"
                        >
                            <div class="h-48 overflow-hidden relative">
                                <img
                                    src={url(
                                        "/images/kompostarna/kompost-detail.jpg",
                                    )}
                                    alt="Náš kompost"
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                />
                                <div
                                    class="absolute top-4 right-4 w-28 h-28 pointer-events-none drop-shadow-md group-hover:scale-105 transition-transform duration-500 z-10"
                                >
                                    <img
                                        src={url(
                                            "/images/kompostarna/pecet-kvality.png",
                                        )}
                                        alt="Pečeť kvality"
                                        class="w-full h-full object-contain"
                                    />
                                </div>
                            </div>
                            <div class="p-6 flex-grow">
                                <h4
                                    class="text-xl font-bold text-slate-900 mb-1 uppercase tracking-wide"
                                >
                                    Kompost
                                </h4>
                                <p class="text-slate-500 text-sm mb-4">
                                    Čistý, vyzrálý, ideální pro hnojení i
                                    terénní úpravy.
                                </p>
                                <div
                                    class="mt-auto pt-4 border-t border-slate-200"
                                >
                                    <span
                                        class="text-amber-600 font-extrabold text-2xl"
                                        >800 Kč/m³</span
                                    >
                                    <span
                                        class="block text-[10px] text-slate-400 font-normal uppercase"
                                        >+ 21% DPH</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Substrát -->
                        <div
                            class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-100 shadow-sm flex flex-col group"
                        >
                            <div class="h-48 overflow-hidden relative">
                                <img
                                    src={url(
                                        "/images/kompostarna/substrat-detail.jpg",
                                    )}
                                    alt="Náš substrát"
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                />
                            </div>
                            <div class="p-6 flex-grow">
                                <h4
                                    class="text-xl font-bold text-slate-900 mb-1 uppercase tracking-wide"
                                >
                                    Substrát
                                </h4>
                                <p class="text-slate-500 text-sm mb-4">
                                    Směs hlíny a vyzrálého kompostu připravená k
                                    okamžitému užití.
                                </p>
                                <div
                                    class="mt-auto pt-4 border-t border-slate-200"
                                >
                                    <span
                                        class="text-amber-600 font-extrabold text-2xl"
                                        >1200 Kč/m³</span
                                    >
                                    <span
                                        class="block text-[10px] text-slate-400 font-normal uppercase"
                                        >+ 21% DPH</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-8">
                    <hr class="border-slate-100" />
                </div>

                <!-- 2. Likvidace bioodpadu -->
                <div
                    class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center scroll-mt-24 md:scroll-mt-32"
                    id="likvidace"
                >
                    <div class="lg:order-2 space-y-8">
                        <h2
                            class="text-3xl md:text-5xl font-extrabold text-slate-900 leading-tight"
                        >
                            Likvidace odpadu<br /> ze zeleně
                        </h2>
                        <p
                            class="text-lg text-slate-600 leading-relaxed max-w-xl"
                        >
                            Veškerý materiál je u nás ekologicky zpracován a
                            přeměněn na užitečný kompost. <button
                                id="openCatalogue"
                                class="text-green-600 font-bold underline hover:text-green-700 transition-colors"
                                >Seznam přijímaných odpadů</button
                            >.
                        </p>

                        <div
                            class="bg-green-50 rounded-xl p-4 border border-green-100 flex items-start gap-3 max-w-xl"
                        >
                            <div
                                class="bg-green-600 rounded-lg p-2 text-white shrink-0"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-slate-900 text-sm">
                                    Přistavení kontejneru
                                </h4>
                                <p class="text-xs text-slate-600 leading-tight">
                                    Pro větší objemy bioodpadu přistavíme
                                    kontejner přímo k vám. Cena služby je
                                    individuální na zavolání.
                                </p>
                            </div>
                        </div>
                        <div class="pt-4 flex flex-wrap gap-4">
                            <a
                                href={url("/kontakt")}
                                class="inline-block bg-green-600 hover:bg-green-700 text-white font-bold py-3 px-8 rounded-lg transition-all hover:scale-105 uppercase tracking-wider text-sm shadow-md"
                            >
                                Poptat
                            </a>
                            <a
                                href={`tel:${CONTACT_INFO.phonePlain}`}
                                class="inline-block bg-white border-2 border-slate-200 hover:border-slate-900 text-slate-700 hover:text-slate-900 font-bold py-3 px-8 rounded-lg transition-all hover:scale-105 uppercase tracking-wider text-sm"
                            >
                                Volejte {CONTACT_INFO.phone}
                            </a>
                        </div>
                    </div>

                    <div class="lg:order-1 flex flex-col gap-6">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                            <!-- Bioodpad -->
                            <div
                                class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-100 shadow-sm flex flex-col group"
                            >
                                <div class="h-48 overflow-hidden relative">
                                    <img
                                        src={url(
                                            "/images/kompostarna/bioodpad-detail.png",
                                        )}
                                        alt="Likvidace bioodpadu"
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    />
                                </div>
                                <div class="p-6 flex-grow">
                                    <h4
                                        class="text-lg font-bold text-slate-900 mb-1 uppercase tracking-wide"
                                    >
                                        Bioodpad
                                    </h4>
                                    <p class="text-slate-500 text-sm mb-4">
                                        Tráva, listí, rostlinné zbytky a drobný
                                        ořez.
                                    </p>
                                    <div
                                        class="mt-auto pt-4 border-t border-slate-200"
                                    >
                                        <span
                                            class="text-green-600 font-extrabold text-2xl"
                                            >600 Kč/t</span
                                        >
                                        <span
                                            class="block text-[10px] text-slate-400 font-normal uppercase"
                                            >+ 21% DPH</span
                                        >
                                    </div>
                                </div>
                            </div>

                            <!-- Kořeny -->
                            <div
                                class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-100 shadow-sm flex flex-col group"
                            >
                                <div class="h-48 overflow-hidden relative">
                                    <img
                                        src={url(
                                            "/images/kompostarna/koreny-detail.png",
                                        )}
                                        alt="Likvidace kořenů"
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                    />
                                </div>
                                <div class="p-6 flex-grow">
                                    <h4
                                        class="text-lg font-bold text-slate-900 mb-1 uppercase tracking-wide"
                                    >
                                        Kořeny, pařezy
                                    </h4>
                                    <p class="text-slate-500 text-sm mb-4">
                                        Objemný dřevní odpad a pařezy stromů.
                                    </p>
                                    <div
                                        class="mt-auto pt-4 border-t border-slate-200"
                                    >
                                        <span
                                            class="text-green-600 font-extrabold text-2xl"
                                            >1000 Kč/t</span
                                        >
                                        <span
                                            class="block text-[10px] text-slate-400 font-normal uppercase"
                                            >+ 21% DPH</span
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Provozní doba -->
    <section class="py-16 bg-slate-50 border-y border-slate-100">
        <div class="container mx-auto px-4">
            <div class="max-w-2xl mx-auto">
                <div
                    class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8"
                >
                    <div class="flex items-center gap-4 mb-6">
                        <div
                            class="bg-amber-100 text-amber-600 p-3 rounded-xl shrink-0"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="h-6 w-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h2
                                class="text-2xl font-extrabold text-slate-900 uppercase tracking-tight"
                            >
                                Provozní <span class="text-amber-600">doba</span
                                >
                            </h2>
                            <span
                                id="seasonBadge"
                                class="inline-block mt-1 text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full"
                            ></span>
                        </div>
                    </div>

                    <!-- Sezóna (březen–říjen) -->
                    <div id="seasonContent" class="hidden">
                        <div class="space-y-3">
                            <div
                                class="flex justify-between items-center py-2 border-b border-slate-100"
                            >
                                <span class="text-slate-600 font-medium"
                                    >Pondělí – Pátek</span
                                >
                                <span class="font-bold text-slate-900 text-lg"
                                    >8:00 – 16:00</span
                                >
                            </div>
                            <div
                                class="flex justify-between items-center py-2 border-b border-slate-100"
                            >
                                <span class="text-slate-600 font-medium"
                                    >Sobota</span
                                >
                                <span class="font-bold text-slate-900 text-lg"
                                    >8:00 – 12:00</span
                                >
                            </div>
                            <div class="flex justify-between items-center py-2">
                                <span class="text-slate-600 font-medium"
                                    >Neděle</span
                                >
                                <span class="font-bold text-slate-400 text-lg"
                                    >Zavřeno</span
                                >
                            </div>
                        </div>
                        <p class="mt-4 text-slate-400 text-xs">
                            Sezóna: březen – říjen
                        </p>
                    </div>

                    <!-- Mimo sezónu (listopad–únor) -->
                    <div id="offSeasonContent" class="hidden">
                        <div class="bg-slate-50 rounded-xl p-6 text-center">
                            <p class="text-slate-600 text-lg font-medium mb-3">
                                Aktuálně je mimo sezónu
                            </p>
                            <p class="text-slate-500 text-sm mb-4">
                                V období listopad – únor fungujeme po
                                individuální domluvě.
                            </p>
                            <a
                                href={`tel:${CONTACT_INFO.phonePlain}`}
                                class="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-slate-900 font-bold py-3 px-6 rounded-lg transition-all hover:scale-105 uppercase tracking-wider text-sm shadow-md"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-4 w-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                    ></path>
                                </svg>
                                Zavolat {CONTACT_INFO.phone}
                            </a>
                        </div>
                        <p class="mt-4 text-slate-400 text-xs">
                            Sezóna začíná opět v březnu.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        function updateSeasonDisplay() {
            const month = new Date().getMonth(); // 0 = leden, 2 = březen, 9 = říjen
            const isSeason = month >= 2 && month <= 9; // březen (2) až říjen (9)

            const seasonContent = document.getElementById("seasonContent");
            const offSeasonContent =
                document.getElementById("offSeasonContent");
            const badge = document.getElementById("seasonBadge");

            if (!seasonContent || !offSeasonContent || !badge) return;

            if (isSeason) {
                seasonContent.classList.remove("hidden");
                offSeasonContent.classList.add("hidden");
                badge.textContent = "Sezóna";
                badge.className =
                    "inline-block mt-1 text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-green-100 text-green-700";
            } else {
                seasonContent.classList.add("hidden");
                offSeasonContent.classList.remove("hidden");
                badge.textContent = "Mimo sezónu";
                badge.className =
                    "inline-block mt-1 text-xs font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full bg-slate-100 text-slate-500";
            }
        }
        updateSeasonDisplay();
    </script>

    <!-- Modal Dialog for Compost Analysis -->
    <dialog
