                    >
                        <thead>
                            <tr
                                class="bg-slate-50 text-slate-700 text-sm font-bold border-b-2 border-slate-200"
                            >
                                <th class="py-3 px-4 sm:px-6">Zkouška</th>
                                <th class="py-3 px-4 sm:px-6 w-24 text-center"
                                    >Jednotka</th
                                >
                                <th class="py-3 px-4 sm:px-6 w-32 text-center"
                                    >Hodnota</th
                                >
                                <th class="py-3 px-4 sm:px-6 w-32 text-center"
                                    >Nejistota</th
                                >
                            </tr>
                        </thead>
                        <tbody class="text-sm text-slate-600">
                            {
                                compostAnalysis.map((item, index) => (
                                    <tr
                                        class={`border-b border-slate-100 ${index % 2 === 0 ? "bg-white" : "bg-slate-50"}`}
