---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaSection from "../components/CtaSection.astro";
import Hero from "../components/Hero.astro";
import SpecsBox from "../components/SpecsBox.astro";
import Gallery from "../components/Gallery.astro";
import { url } from "../utils/urls";

const specs = [
    {
        label: "Typ vozidla",
        value: "Tatra Phoenix 6x6 (Euro 5)",
        icon: "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0zM13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 011 1v1m4-1a1 1 0 011 1v1m-1-4h3a1 1 0 001-1V11a1 1 0 00-1-1h-3V8a1 1 0 00-1-1h-5",
    },
    {
        label: "Kapacita kontejnerů",
        value: "8 m³ až 35 m³",
        icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    },
];

const galleryImages = [
    {
        src: "/images/kontejnerova-doprava/1.webp",
        alt: "Tatra Phoenix v terénu",
    },
    {
        src: "/images/kontejnerova-doprava/2.webp",
        alt: "Přistavení kontejneru",
    },
    { src: "/images/kontejnerova-doprava/3.webp", alt: "Odvoz odpadu" },
    { src: "/images/kontejnerova-doprava/4.webp", alt: "Tatra Phoenix detail" },
    { src: "/images/kontejnerova-doprava/5.webp", alt: "Nakládka kontejneru" },
    { src: "/images/kontejnerova-doprava/6.webp", alt: "Sklápění materiálu" },
];
---

<BaseLayout
    title="Jan Musil - Kontejnerová doprava | Přistavení kontejnerů a odvoz suti"
    fullWidth={true}
    transparentNav={true}
>
    <Hero
        image="/images/kontejnerova-doprava/hero.webp"
        imageAlt="Kontejnerová doprava Tatra Phoenix"
    >
        <Fragment slot="title">
            Kontejnerová doprava <br />
            <span class="text-amber-500">vozem Tatra Phoenix</span>
        </Fragment>
        <Fragment slot="subtitle">
            Nabízíme pronájem kontejnerů na sutě a odpady, odvoz stavebního
            materiálu i přepravu stavební techniky. S pohonem 6x6 pro nás není
            problém ani náročný terén.
        </Fragment>
        <Fragment slot="actions">
            <a
                href="#kontakt"
                class="inline-block bg-amber-500 hover:bg-amber-600 text-slate-900 font-bold py-4 px-8 rounded-lg transition-transform hover:scale-105 shadow-lg uppercase tracking-wider text-sm"
            >
                Poptat dopravu
            </a>
        </Fragment>
    </Hero>

    <!-- Machine Specs Section -->
    <section class="py-16 md:py-24">
        <div class="container mx-auto px-4">
            <div class="flex flex-col md:flex-row gap-24 items-center">
                <div class="w-full md:w-1/2">
                    <SpecsBox title="Parametry vozidla" specs={specs} />
                </div>
                <div class="w-full md:w-1/2 text-slate-700">
                    <h2 class="text-3xl font-bold mb-6 text-slate-900">
                        Špičková technika pro Vaši stavbu
                    </h2>
                    <p class="mb-6 leading-relaxed text-lg">
                        Pro kontejnerovou dopravu využíváme moderní vozidlo <strong
                            >Tatra Phoenix 6x6</strong
                        >. Tento legendární český podvozek v kombinaci s
                        výkonným motorem a hákovým nosičem kontejnerů zaručuje,
                        že Váš náklad doručíme včas a kamkoliv.
                    </p>
                    <div class="space-y-4">
                        <div class="flex items-start gap-3">
                            <div class="mt-1 text-amber-500">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <p>
                                Přistavení kontejnerů na sutě a stavební odpady
                            </p>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="mt-1 text-amber-500">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <p>
                                Přeprava písků, štěrků, betonových směsí a
                                zeminy
                            </p>
                        </div>
                        <div class="flex items-start gap-3">
                            <div class="mt-1 text-amber-500">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    class="h-5 w-5"
                                    viewBox="0 0 20 20"
                                    fill="currentColor"
                                >
                                    <path
                                        fill-rule="evenodd"
                                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </div>
                            <p>
                                Přeprava stavební mechanizace a paletového zboží
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Section -->
    <Gallery images={galleryImages} />

    <!-- CTA Section -->
    <CtaSection />
</BaseLayout>
